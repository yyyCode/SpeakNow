# 构建产物（用 GitHub Release 分发大 exe，勿提交进仓库）
speaknow.exe
speaknow-core.exe
/libvosk.dll
/libgcc_s_seh-1.dll
/libstdc++-6.dll
/libwinpthread-1.dll
backend/cmd/launcher/payload/*
!backend/cmd/launcher/payload/.gitkeep
/bin/
/dist/
*.exe~

# 由 prepare-bundle 从 model/web/ 生成，体积大，换机后跑脚本即可
backend/internal/assets/model/*
!backend/internal/assets/model/.gitkeep
backend/internal/assets/web/*
!backend/internal/assets/web/.gitkeep

# 可选：zip 原件较大时用 scripts/setup-vosk.ps1 下载，不必提交
# third_party/vosk-win64.zip

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 环境变量（可选本地覆盖）
.env
.env.*
!.env.example

# 日志与运行时数据
*.log
logs/
data/
.speaknow-data/
vosk-runtime/

# PR 分析报告（本地生成，勿提交）
reports/pr/

# Go vendor（若使用 vendor 目录再单独处理）
vendor/

